---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Free Granny Flat Design Consultation | Frankston & Peninsula | (03) 9003 0108"
  description="Get a free on-site design consultation for your Frankston, Mt Eliza, Mornington or Peninsula granny flat. 60-min visit + fixed quote within 7 days."
  canonical="https://frankstongrannyflats.com.au/quote/">

  <section class="hero" style="padding: 2.5rem 0 3rem;">
    <div class="hero-inner">
      <span class="hero-eyebrow">Free Consultation</span>
      <h1>Book your free design consultation.</h1>
      <p class="hero-sub">
        Tell us about your block and what you want to build. We&rsquo;ll come on-site
        for a 60-min consultation and email a fixed-price quote within 7 days. Free,
        no obligation.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="form-wrap">
        <div class="form-card">
          <form
            name="quote"
            method="POST"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
            action="/thanks/">
            <input type="hidden" name="form-name" value="quote" />
            <p style="display:none;">
              <label>Don&rsquo;t fill this out: <input name="bot-field" /></label>
            </p>

            <label for="name">Your name</label>
            <input id="name" name="name" type="text" autocomplete="name" required />

            <label for="phone">Phone number</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" required placeholder="04xx xxx xxx" />

            <label for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />

            <label for="suburb">Suburb / postcode</label>
            <input id="suburb" name="suburb" type="text" autocomplete="address-level2" required placeholder="e.g. Frankston South 3199, Mt Eliza 3930, Mornington 3931" />

            <label for="format">What format are you considering?</label>
            <select id="format" name="format">
              <option value="not-sure">Not sure &mdash; want a recommendation</option>
              <option value="one-bedroom">1-bedroom granny flat (35-50m&sup2;)</option>
              <option value="two-bedroom">2-bedroom granny flat (60-90m&sup2;)</option>
              <option value="dual-occupancy">Dual-occupancy second dwelling (subdivision-ready)</option>
              <option value="garden-studio">Garden studio / home office (no permit)</option>
              <option value="ndis-sda">NDIS SDA-compliant build</option>
              <option value="combination">Combination / not sure yet</option>
            </select>

            <label for="purpose">What is it for?</label>
            <select id="purpose" name="purpose">
              <option value="not-sure">Not sure</option>
              <option value="ageing-parent">Ageing parent / family member</option>
              <option value="adult-child">Adult child living at home</option>
              <option value="long-term-rental">Long-term rental income</option>
              <option value="short-stay">Short-stay / Airbnb (Peninsula registration)</option>
              <option value="ndis-participant">NDIS participant (family member)</option>
              <option value="ndis-investor">NDIS SDA investment property</option>
              <option value="home-office">Home office / workspace</option>
              <option value="subdivision">Subdivision-ready dual-occupancy</option>
              <option value="other">Other</option>
            </select>

            <label for="block-size">Approximate block size (m&sup2;)</label>
            <select id="block-size" name="block-size">
              <option value="not-sure">Not sure</option>
              <option value="small">Under 400m&sup2; (most of Carrum Downs / Seaford)</option>
              <option value="medium">400-700m&sup2; (typical Frankston City)</option>
              <option value="large">700-1,000m&sup2; (typical Frankston South)</option>
              <option value="extra-large">1,000m&sup2;+ (typical Mt Eliza / acreage)</option>
            </select>

            <label for="timeframe">When do you want it built?</label>
            <select id="timeframe" name="timeframe">
              <option value="asap">ASAP - next 3 months</option>
              <option value="3-6-months">3-6 months</option>
              <option value="6-12-months">6-12 months</option>
              <option value="12+">12 months or longer (research stage)</option>
              <option value="not-sure">Not sure yet</option>
            </select>

            <label for="message">Any details? (optional)</label>
            <textarea id="message" name="message" rows="4" placeholder="Existing house age, known site constraints, council overlay concerns, budget range, deadline, etc."></textarea>

            <button class="btn btn-primary btn-block" type="submit">Send my consultation request</button>

            <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--c-muted);">
              We reply within 1 business day. Free, no obligation.
            </p>
          </form>
        </div>

        <aside class="form-aside">
          <h3>Prefer to talk?</h3>

          <div class="info-row">
            <span aria-hidden="true" style="font-size:1.5rem; line-height:1;">&#9742;</span>
            <div>
              <strong>Phone</strong>
              <a href="tel:+61390030108">(03) 9003 0108</a>
              <p style="font-size:0.85rem; color:var(--c-muted); margin:0;">Mon&ndash;Sat 7am&ndash;6pm</p>
            </div>
          </div>

          <div class="info-row">
            <span aria-hidden="true" style="font-size:1.5rem; line-height:1;">&#9978;</span>
            <div>
              <strong>Service area</strong>
              <p style="margin:0;">Frankston City + Mornington Peninsula Shire &mdash; from Seaford through to Portsea.</p>
            </div>
          </div>

          <div class="info-row">
            <span aria-hidden="true" style="font-size:1.5rem; line-height:1;">&#10004;</span>
            <div>
              <strong>What you&rsquo;ll get</strong>
              <ul style="margin:0.4rem 0 0; padding-left:1rem; font-size:0.95rem; color:var(--c-text);">
                <li>Free on-site 60-min design consultation</li>
                <li>Site survey, soil check, services audit, council zone check</li>
                <li>Concept sketches + NatHERS pre-assessment</li>
                <li>Fixed-price written quote within 7 days</li>
                <li>VicSmart fast-track or full planning permit pathway advice</li>
              </ul>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
